---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { questions } from "@/data/questions";
---

<BaseLayout
  title="차트로드 테스트 | 28문항 차트 공부 순서 진단"
  description="28문항으로 차트 이해도, 매매 기준, 리스크 성향을 점검하고 교육용 차트 학습 로드맵을 확인하세요."
>
  <section class="test-shell">
    <div class="container">
      <div class="card" id="test-app" data-questions={JSON.stringify(questions)}>
        <div class="progress" aria-label="진행률"><span id="progress-bar"></span></div>
        <p class="meta" id="progress-text" style="margin-top:12px">1 / 28</p>
        <h1 id="question-text" style="font-size:clamp(28px,4vw,44px); margin-top:18px">질문을 불러오는 중입니다</h1>
        <div class="option-grid" id="options"></div>
        <div class="actions" style="justify-content:space-between">
          <button class="btn light" id="prev-button" type="button">이전</button>
          <button class="btn dark" id="next-button" type="button">다음</button>
        </div>
        <p class="meta" style="margin-top:16px">답변은 브라우저에만 임시 저장되며, 회원가입 없이 결과를 확인할 수 있습니다.</p>
      </div>
    </div>
  </section>
  <script is:inline src="/scripts/test.js"></script>
</BaseLayout>
