---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { resultProfiles } from "@/data/results";
---

<BaseLayout title="차트로드 결과 유형 12가지" description="차트로드 테스트에서 나올 수 있는 12가지 차트 공부 성향 유형을 확인하세요.">
  <section class="section tight">
    <div class="container">
      <h1>차트로드 결과 유형 12가지</h1>
      <p class="sublead">각 유형은 투자 판단이 아니라 차트 공부 순서를 정리하기 위한 교육용 분류입니다.</p>
      <div class="grid cols-3" style="margin-top:24px">
        {resultProfiles.map((profile) => (
          <article class="card" id={profile.key}>
            <small>{profile.meaning}</small>
            <h2 style="font-size:26px; margin-top:8px">{profile.name}</h2>
            <p class="meta" style="margin-top:10px">{profile.description}</p>
            <h3 style="margin-top:18px">먼저 공부할 개념</h3>
            <ol class="list">{profile.recommendedStudy.map((item) => <li>{item}</li>)}</ol>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
