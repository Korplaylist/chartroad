---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articles, articleMap } from "@/data/articles";

export function getStaticPaths() {
  return articles.map((article) => ({ params: { slug: article.slug } }));
}

const article = articleMap[Astro.params.slug ?? ""];

const faqJson = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: article.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
};
const articleJson = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.summary,
  inLanguage: "ko-KR",
};
const breadcrumbJson = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "홈", item: "https://chartroad.pages.dev/" },
    { "@type": "ListItem", position: 2, name: "공부 콘텐츠", item: "https://chartroad.pages.dev/learn" },
    { "@type": "ListItem", position: 3, name: article.title },
  ],
};

const companionImages = article.images?.slice(1) ?? [];
const inlineImageAt = (index: number) => companionImages[index === 1 ? 0 : index === 4 ? 1 : index === 7 ? 2 : -1];
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? "https://chartroad.pages.dev").toString();
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(article.title);
const relatedArticles = articles
  .filter((item) => item.slug !== article.slug)
  .map((item) => ({
    article: item,
    score:
      (item.category === article.category ? 4 : 0) +
      item.concepts.filter((concept) => article.concepts.includes(concept)).length * 3 +
      (item.slug.split("-")[0] === article.slug.split("-")[0] ? 1 : 0),
  }))
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || a.article.title.localeCompare(b.article.title, "ko"))
  .slice(0, 6)
  .map((item) => item.article);
---

<BaseLayout title={`${article.title} | 차트로드`} description={article.summary}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJson)} slot="head"></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqJson)} slot="head"></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)} slot="head"></script>

  <section class="section tight article-section">
    <div class="article-container">
      <div class="breadcrumb">
        <a href="/">홈</a> / <a href="/learn">공부 콘텐츠</a> / {article.title}
      </div>

      <article class="card article-body article-main">
        <small>{article.category}</small>
        <h1>{article.title}</h1>
        <p class="article-summary">{article.summary}</p>
        <div class="tag-row">
          {article.concepts.map((concept) => <span class="tag">{concept}</span>)}
        </div>
        {article.images?.[0] && (
          <figure class="article-hero-figure">
            <img src={article.images[0].src} alt={article.images[0].alt} width="960" height="540" loading="eager" decoding="async" />
            <figcaption>{article.images[0].caption}</figcaption>
          </figure>
        )}
        <hr />
        {article.bodyHtml
          ? article.bodyHtml.map((block, index) => (
              <>
                <div class="article-rich-block" set:html={block} />
                {inlineImageAt(index) && (
                  <figure class="article-figure">
                    <img src={inlineImageAt(index)?.src} alt={inlineImageAt(index)?.alt} width="960" height="540" loading="lazy" decoding="async" />
                    <figcaption>{inlineImageAt(index)?.caption}</figcaption>
                  </figure>
                )}
              </>
            ))
          : article.body.map((paragraph) => <p>{paragraph}</p>)}

        <h2>자주 묻는 질문</h2>
        {article.faq.map((item) => (
          <section class="faq-item">
            <h3>{item.question}</h3>
            <p class="meta">{item.answer}</p>
          </section>
        ))}

        <section class="share-section" aria-labelledby="share-title">
          <h2 id="share-title">공유하기</h2>
          <div class="share-row">
            <a class="share-button" href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer">X</a>
            <a class="share-button" href={`https://share.naver.com/web/shareView?url=${encodedUrl}&title=${encodedTitle}`} target="_blank" rel="noopener noreferrer">네이버 블로그</a>
            <a class="share-button" href={`kakaotalk://sendurl?msg=${encodedTitle}&url=${encodedUrl}`}>카카오톡</a>
            <a class="share-button" href={`https://story.kakao.com/share?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer">카카오스토리</a>
          </div>
        </section>

        {relatedArticles.length > 0 && (
          <section class="related-section" aria-labelledby="related-title">
            <h2 id="related-title">관련 글</h2>
            <div class="related-grid">
              {relatedArticles.map((item) => (
                <a class="related-card" href={`/learn/${item.slug}/`}>
                  <small>{item.category}</small>
                  <h3>{item.title}</h3>
                  <p>{item.summary}</p>
                </a>
              ))}
            </div>
          </section>
        )}
      </article>
    </div>
  </section>
</BaseLayout>
