---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articles, articleMap } from "@/data/articles";

export function getStaticPaths() {
  return articles.map((article) => ({ params: { slug: article.slug } }));
}

const article = articleMap[Astro.params.slug ?? ""];
const related = articles
  .filter(
    (item) =>
      item.slug !== article.slug &&
      (item.category === article.category ||
        item.concepts.some((concept) => article.concepts.includes(concept)))
  )
  .slice(0, 3);

const faqJson = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: article.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
};
const articleJson = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: article.title,
  description: article.summary,
  inLanguage: "ko-KR",
};
const breadcrumbJson = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "홈", item: "https://chartroad.pages.dev/" },
    { "@type": "ListItem", position: 2, name: "공부 콘텐츠", item: "https://chartroad.pages.dev/learn" },
    { "@type": "ListItem", position: 3, name: article.title },
  ],
};
---

<BaseLayout title={`${article.title} | 차트로드`} description={article.summary}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJson)} slot="head"></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqJson)} slot="head"></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJson)} slot="head"></script>

  <section class="section tight article-section">
    <div class="article-container">
      <div class="breadcrumb">
        <a href="/">홈</a> / <a href="/learn">공부 콘텐츠</a> / {article.title}
      </div>

      <article class="card article-body article-main">
        <small>{article.category}</small>
        <h1>{article.title}</h1>
        <p class="article-summary">{article.summary}</p>
        <div class="tag-row">
          {article.concepts.map((concept) => <span class="tag">{concept}</span>)}
        </div>
        {article.images?.[0] && (
          <figure class="article-hero-figure">
            <img src={article.images[0].src} alt={article.images[0].alt} width="960" height="540" loading="eager" decoding="async" />
            <figcaption>{article.images[0].caption}</figcaption>
          </figure>
        )}
        <hr />
        {article.images?.slice(1).map((image) => (
          <figure class="article-figure">
            <img src={image.src} alt={image.alt} width="960" height="540" loading="eager" decoding="async" />
            <figcaption>{image.caption}</figcaption>
          </figure>
        ))}
        {article.bodyHtml
          ? article.bodyHtml.map((block) => <div class="article-rich-block" set:html={block} />)
          : article.body.map((paragraph) => <p>{paragraph}</p>)}

        <h2>자주 묻는 질문</h2>
        {article.faq.map((item) => (
          <section class="faq-item">
            <h3>{item.question}</h3>
            <p class="meta">{item.answer}</p>
          </section>
        ))}
      </article>

      <section class="related-section">
        <h2>관련 글 추천</h2>
        <p class="sublead">이 글과 같은 카테고리 또는 연결된 개념을 이어서 읽어보세요.</p>
        <div class="grid cols-3 related-grid">
          {related.map((item) => (
            <a class="card" href={`/learn/${item.slug}`}>
              <small>{item.category}</small>
              <h3>{item.title}</h3>
              <p class="meta">{item.summary}</p>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
