---
import globalCss from "@/styles/global.css?inline";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  ogType?: "website" | "article";
  robots?: string;
};

const {
  title = "차트로드 | 차트 공부 순서와 교육 로드맵",
  description = "차트로드는 캔들, 거래량, 이동평균선, 지지선과 저항선, 보조지표, 리스크 관리를 단계별로 정리한 차트 공부 교육 사이트입니다.",
  image = "/assets/chartroad-og.webp",
  ogType = "website",
  robots = "index, follow, max-image-preview:large",
} = Astro.props;

const site = Astro.site ?? "https://chartroad.co.kr";
const canonical = new URL(Astro.url.pathname, site).toString();
const absoluteImage = new URL(image, site).toString();
const websiteJson = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "차트로드",
  url: site.toString(),
  inLanguage: "ko-KR",
  description,
  potentialAction: {
    "@type": "SearchAction",
    target: "https://chartroad.co.kr/search/?q={search_term_string}",
    "query-input": "required name=search_term_string",
  },
};
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/assets/chartroad-mark.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="차트로드 RSS" href="/rss.xml" />
    <meta name="theme-color" content="#1d3a3a" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="차트로드" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <style set:html={globalCss}></style>
    <script type="application/ld+json" set:html={JSON.stringify(websiteJson)}></script>
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="주요 메뉴">
        <a class="brand" href="/" aria-label="차트로드 홈">
          <span class="brand-mark"><img src="/assets/chartroad-mark.svg" alt="" width="38" height="38" decoding="async" /></span>
          <span>차트로드</span>
        </a>
        <div class="nav-links">
          <a href="/test">테스트</a>
          <a href="/learn">공부 콘텐츠</a>
          <a href="/results">결과 유형</a>
          <a class="nav-search-link" href="/search" aria-label="글 검색">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m21 21-4.35-4.35m1.35-5.15a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z" />
            </svg>
          </a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="container footer-grid">
        <div>
          <strong>차트로드</strong>
          <p class="disclaimer">
            차트로드의 모든 콘텐츠는 차트 학습을 돕기 위한 교육 정보입니다. 특정 종목의 매수·매도 추천, 투자 자문, 수익 보장을 제공하지 않습니다.
            투자 판단과 책임은 사용자 본인에게 있습니다.
          </p>
        </div>
        <div class="nav-links">
          <a href="/about">소개</a>
          <a href="/disclaimer">유의사항</a>
          <a href="/privacy">개인정보처리방침</a>
          <a href="/contact">문의</a>
        </div>
      </div>
    </footer>
  </body>
</html>
